# GitHub Actions self-hosted runner — env template for docker run --env-file
# Copy to e.g. my-repo.env and fill in real values. Do not commit secrets.
# Use: docker run ... --env-file my-repo.env ...

# Repo this runner will register with (GitHub repo URL)
REPO_URL=https://github.com/your-org/your-repo

# One-time registration token from: Repo → Settings → Actions → Runners → New self-hosted runner
RUNNER_TOKEN=your-registration-token-here

# Display name for this runner (e.g. in GitHub UI). Must be unique per repo.
RUNNER_NAME=docker-your-org-your-repo

# Comma-separated labels (used in workflow runs-on). Default: self-hosted,docker
RUNNER_LABELS=self-hosted,docker

# Work directory for runner jobs. Must match the -v mount path (default: /tmp/github-runner-work)
# RUNNER_WORK_DIR=/tmp/github-runner-work

# Optional: skip the "work dir must be a bind mount" check (set to 1 to enable).
# Use on Docker Desktop for Mac if you see that error despite adding the correct -v mount.
# RUNNER_SKIP_WORK_DIR_MOUNT_CHECK=1

# Optional: host Docker group GID if different from 999 (Linux: getent group docker | cut -d: -f3)
# DOCKER_GID=999
