# GitHub Actions self-hosted runner — sample env file
# Copy to e.g. env/my-repo.env and fill in real values. Do not commit secrets.

# Repo this runner will register with (GitHub repo URL)
REPO_URL=https://github.com/your-org/your-repo

# One-time registration token from: Repo → Settings → Actions → Runners → New self-hosted runner
RUNNER_TOKEN=your-registration-token-here

# Display name for this runner (e.g. in GitHub UI). Must be unique per repo.
RUNNER_NAME=docker-your-org-your-repo

# Comma-separated labels (used in workflow runs-on). Default: self-hosted,docker
RUNNER_LABELS=self-hosted,docker,your-repo

# Path to this env file (used by Compose for variable substitution). Update when you copy this file.
ENV_FILE=env/sample.env


# Work directory for runner jobs. Must be unique per runner when running multiple (default: /tmp/github-runner-work)
# For multiple runners, set e.g. RUNNER_WORK_DIR=/tmp/github-runner-work/docker-your-org-your-repo
# RUNNER_WORK_DIR=/tmp/github-runner-work

# Optional: skip the "work dir must be a bind mount" check (set to 1 to enable).
# Use on Docker Desktop for Mac if you see that error despite adding the correct -v mount for RUNNER_WORK_DIR.
# RUNNER_SKIP_WORK_DIR_MOUNT_CHECK=1

# Optional: host Docker group GID if runner needs to use host Docker (default: 999)
# Find on Linux: getent group docker | cut -d: -f3
# DOCKER_GID=999
